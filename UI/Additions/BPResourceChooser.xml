<?xml version="1.0" encoding="utf-8"?>
<!--
  资源选择器弹窗(按 Firaxis 官方模态模态弹窗骨架编写)。
  参考蓝本:
    DLC/Babylon/UI/Additions/HeroesPopup.xml
    Base/Assets/UI/Popups/GreatPeoplePopup.xml

  关键点:
    - <Context> 根,由 <AddUserInterfaces><Context>InGame</Context></AddUserInterfaces>
      自动挂到 /InGame/AdditionalUserInterfaces;不要 reparent 到 WorldPopups。
    - <Container Style="FullScreenVignetteConsumer"/> 全屏暗化背景。
    - <BoxButton ScreenConsumer> 吞掉世界点击和鼠标滚轮,右键触发关闭。
    - 可见性由 UIManager:QueuePopup / DequeuePopup 统一管理,不在 XML 里 Hidden。
-->
<Context>
  <Container ID="ChooserRoot" Size="parent,parent">
    <!-- 全屏暗化背景 -->
    <Container Style="FullScreenVignetteConsumer"/>

    <!-- 整屏吞点击/滚轮;右键 → 关闭 -->
    <BoxButton
      ID="ScreenConsumer"
      Anchor="C,C"
      Size="parent,parent"
      Color="0,0,0,0"
      ConsumeMouseButton="1"
      ConsumeMouseWheel="1"/>

    <!-- 弹窗主体 -->
    <Grid
      ID="ChooserPanel"
      Anchor="C,C"
      Size="640,660"
      Style="EventPopupFrame"
      ConsumeMouseOver="1">
      <!-- 标题栏(参 EventPopup.xml:29-33 / HeroesPopup.xml:10-12):
           标题装饰 Grid 包住 Label,Label 不设 Size,仅靠 Anchor="C,C" +
           WrapWidth + Align="Center" 在固定宽容器里居中。EventPopupTitle
           Style 本身已带 Align="Center",这里再写 Align="Center" 是官方
           习惯做法(EventPopup.xml:32 同样重复声明)。 -->
      <Grid
        Style="EventPopupTitleBar"
        Size="parent-32,52"
        Offset="0,12"
        Anchor="C,T">
        <Label
          ID="ChooserTitle"
          Style="EventPopupTitle"
          Offset="0,2"
          Align="Center"
          WrapWidth="560"
          String="LOC_BP_RESOURCE_CHOOSER_TITLE"
          Anchor="C,C"/>
      </Grid>

      <!-- 提示文本(参 EventPopup.xml:34-35 / HeroesPopup.xml:16-18):
           外层 Container 给固定宽高,Label 无 Size 只靠 Align="Center" +
           WrapWidth 在容器里居中,避免直接给 Label 设 Size 造成换行错位。 -->
      <Container
        Size="parent-32,44"
        Offset="0,72"
        Anchor="C,T">
        <Label
          ID="ChooserPrompt"
          Style="EventPopupDescription"
          Align="Center"
          WrapWidth="parent-20"
          String="LOC_BP_RESOURCE_CHOOSER_PROMPT"
          Anchor="C,C"/>
      </Container>

      <!-- 资源分类筛选标签条(参 ReportScreen.xml:15-26 + TabSupport.lua)。
           TabContainer 由 InstanceManager 灌入 TabInstance(见文件末尾的
           <Instance Name="TabInstance">),每枚标签用官方 TabButton Style,
           内层 TabButtonSelected 子控件由 Lua 切换 Hide 表达选中态。 -->
      <Container
        ID="FilterTabArea"
        Anchor="C,T"
        Offset="0,120"
        Size="parent-32,40">
        <Container
          ID="FilterTabContainer"
          Anchor="C,C"
          Size="parent,34"/>
      </Container>

      <Grid
        ID="ChooserListFrame"
        Anchor="C,T"
        Offset="0,168"
        Size="580,388"
        Texture="Controls_DrawerUp"
        SliceCorner="5,4"
        SliceSize="3,2"
        SliceTextureSize="14,8">
        <ScrollPanel
          ID="ChooserScrollPanel"
          Anchor="C,C"
          Size="parent-18,parent-18"
          Vertical="1"
          AutoScrollBar="1">
          <ScrollBar Anchor="R,C" Size="11,100" Style="ScrollVerticalBar"/>
          <Stack
            ID="ChooserListStack"
            Anchor="C,T"
            Size="parent-20,auto"
            StackGrowth="Bottom"
            StackPadding="8"/>
        </ScrollPanel>

        <!-- "当前类别无可种资源"占位提示:默认 Hidden,RefreshList 在过滤后
             命中空集时 Lua 显示此 Label。 -->
        <Label
          ID="EmptyHint"
          Anchor="C,C"
          Style="EventPopupDescription"
          Align="Center"
          WrapWidth="parent-20"
          String="LOC_BP_RESOURCE_CHOOSER_EMPTY_HINT"
          Hidden="1"/>
      </Grid>

      <!-- 取消按钮(参 BoostUnlockedPopup.xml:38 / TechCivicCompletedPopup.xml:55):
           Anchor="C,B" 必须配【正】y Offset 才会贴在 Grid 内底;负值会把
           按钮推到 Grid 外下方,造成"跑出界面"。 -->
      <GridButton
        ID="CancelButton"
        Anchor="C,B"
        Offset="0,40"
        Size="220,41"
        Style="MainButton"
        String="LOC_CANCEL"/>
    </Grid>
  </Container>

  <!-- 资源条目实例模板:InstanceManager 用 "Button" 作为根控件名。
       不设 ConsumeMouse="1" —— 这样悬停在条目上时滚轮仍能驱动外层
       ScrollPanel 滚动(官方 GreatPeoplePopup PastRecruitmentInstance 同样未设)。 -->
  <Instance Name="ResourceEntryInstance">
    <GridButton
      ID="Button"
      Anchor="C,T"
      Size="520,56"
      Texture="Controls_ButtonControl"
      SliceCorner="10,10"
      SliceSize="1,1"
      SliceTextureSize="24,24"
      StateOffsetIncrement="0,24">
      <Image ID="ResourceIcon" Anchor="L,C" Offset="18,0" Size="38,38"/>
      <Label ID="ResourceName" Anchor="L,C" Offset="70,0" Style="EventPopupDescription" TruncateWidth="420"/>
    </GridButton>
  </Instance>

  <!-- 资源分类筛选标签实例(参 ReportScreen.xml:151-157):
       外层 GridButton 用官方 TabButton Style 承载点击与文字;
       内层 AlphaAnim 裹一个 Hidden 的 TabButtonSelected GridButton
       作为"选中态"贴图,Lua 用 SetHide(false/true) 切换。 -->
  <Instance Name="TabInstance">
    <GridButton
      ID="Button"
      Size="80,34"
      Style="TabButton"
      FontSize="14"
      TextOffset="0,2">
      <AlphaAnim
        ID="Selection"
        Offset="-2,0"
        Size="parent+3,parent"
        Speed="4"
        AlphaBegin="0"
        AlphaEnd="1"
        Cycle="Once"
        Function="Root"
        Hidden="1">
        <GridButton
          Size="parent,parent"
          Style="TabButtonSelected"
          ConsumeMouseButton="0"
          ConsumeMouseOver="1"/>
      </AlphaAnim>
    </GridButton>
  </Instance>
</Context>
